# ── Force HTTPS ───────────────────────────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Remove trailing slash injection ──────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# ── Security Headers ──────────────────────────────────────────────────────────
Header always set X-Frame-Options "DENY"
Header always set X-Content-Type-Options "nosniff"
Header always set X-XSS-Protection "0"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=(), accelerometer=(), gyroscope=()"
Header always set Cross-Origin-Opener-Policy "same-origin"
Header always set Cross-Origin-Embedder-Policy "require-corp"
Header always set Cross-Origin-Resource-Policy "same-origin"
Header always unset X-Powered-By
Header always unset Server
Header always unset X-AspNet-Version
Header always unset X-AspNetMvc-Version

# ── Content Security Policy (strict) ─────────────────────────────────────────
Header always set Content-Security-Policy "default-src 'none'; script-src 'self' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data:; frame-src https://maps.google.com https://www.google.com; connect-src 'none'; base-uri 'self'; form-action 'self' https://wa.me; object-src 'none'; media-src 'none'; worker-src 'none'; manifest-src 'self';"

# ── Cache Control ─────────────────────────────────────────────────────────────
<FilesMatch "\.(html|htm)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>
<FilesMatch "\.(css|js)$">
  Header set Cache-Control "public, max-age=2592000, immutable"
</FilesMatch>
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|ttf|eot)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# ── Custom Error Pages ────────────────────────────────────────────────────────
ErrorDocument 400 /404.html
ErrorDocument 401 /404.html
ErrorDocument 403 /404.html
ErrorDocument 404 /404.html
ErrorDocument 405 /404.html
ErrorDocument 500 /404.html
ErrorDocument 503 /404.html

# ── Disable Directory Listing ─────────────────────────────────────────────────
Options -Indexes -MultiViews

# ── Hide Server Signature ─────────────────────────────────────────────────────
ServerSignature Off

# ── Block Access to Sensitive Files ──────────────────────────────────────────
<FilesMatch "(^\.htaccess|\.htpasswd|\.env|\.git|\.log|\.bak|\.sql|\.conf|\.ini|\.sh|\.py|\.rb|\.pl|composer\.json|package\.json|package-lock\.json|yarn\.lock|webpack\.config\.js|Makefile|Dockerfile)$">
  Require all denied
</FilesMatch>

# ── Block Sensitive Paths ─────────────────────────────────────────────────────
RewriteRule ^(\.git|\.env|node_modules|vendor|wp-admin|wp-login|phpmyadmin|adminer|xmlrpc) - [F,L]

# ── Block Bad Bots & Scanners ─────────────────────────────────────────────────
SetEnvIfNoCase User-Agent "Nikto|sqlmap|Acunetix|dirbuster|Nessus|OpenVAS|Masscan|ZmEu|Havij|w3af|Metasploit|libwww-perl|python-requests|curl/7|wget/" bad_bot
<RequireAll>
  Require all granted
  Require not env bad_bot
</RequireAll>

# ── Block SQL Injection / LFI attempts in query string ───────────────────────
RewriteCond %{QUERY_STRING} (union.*select|select.*from|insert.*into|drop.*table|<script|javascript:|vbscript:|onload=|onerror=|alert\(|\.\./) [NC]
RewriteRule .* - [F,L]

# ── Block common exploit file extensions ──────────────────────────────────────
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|phar|cgi|pl|py|rb|sh|bash|exe|dll|cmd|bat|msi)$">
  Require all denied
</FilesMatch>

# ── Prevent MIME Sniffing / Type confusion ────────────────────────────────────
AddType text/html .html .htm
AddType text/css .css
AddType application/javascript .js

# ── Limit HTTP Methods ────────────────────────────────────────────────────────
RewriteCond %{REQUEST_METHOD} !^(GET|POST|HEAD)$
RewriteRule .* - [F,L]

# ── Block requests with no User-Agent ────────────────────────────────────────
RewriteCond %{HTTP_USER_AGENT} ^-?$
RewriteRule .* - [F,L]

# ── Compress Text Files ───────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/xml application/xml text/plain
</IfModule>

# ── Disable ETags (prevent inode info leak) ───────────────────────────────────
FileETag None
Header unset ETag
